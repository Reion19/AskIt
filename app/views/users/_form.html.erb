<%= render "shared/errors", object: @user%>
<%= form_with model: @user do |f| %>
  <div class="mb-3 row">
  </div>
  <div class="mb-3 row">
    <div class="col-sm-2 col-form-label">
      <%= f.label :name%>
    </div>
    <div class="col-sm-10 col-form-label">
      <%= f.text_field :name, placeholder: "Name", class:"form-control"%>
    </div>
    <div class="mb-3 row">
      <div class="col-sm-2 col-form-label">
        <%= f.label :email%>
      </div>
      <div class="col-sm-10 col-form-label">
        <%= f.email_field :email, required: true, placeholder: "email@example.com", class:"form-control form-control-lg"%>
      </div>
      <div class="col-sm-2 col-form-label">
        <%= f.label :password%>
      </div>
      <div class="col-sm-10 col-form-label">
        <%= f.password_field :password, required: true, minlength: 3, class:"form-control"%>
      </div>
      <div class="col-sm-2 col-form-label">
        <%= f.label :password%>
      </div>
      <div class="col-sm-10 col-form-label">
        <%= f.password_field :password_confirmation, required: true, minlength: 3, class:"form-control"%>
      </div>
    </div>
    <%= f.submit "Register!", class: "btn btn-primary btn-lg" %>
  <%end%>