<%= currently_at "Log In" %>

<% provide :page_title, 'Log In' %>

<%= render "shared/errors", object: @user%>

<%= form_with url: session_path, data: {turbo: false} do |f| %>
  <div class="mb-3 row">
    <div class="col-sm-2 col-form-label" >
      <%= f.label :email%>
    </div>

    <div class="col-sm-10">
      <%= f.email_field :email, requried: true,  placeholder: "some@mail.com", class: " form-control form-control-lg" %>
    </div>
  </div>

  <div class="mb-3 row">
    <div class="col-sm-2 col-form-label">
      <%= f.label :password %>
    </div>

    <div class="col-sm-10">
      <%= f.password_field :password, requried: true, class: "form-control form-control-lg" %>
    </div>
  </div>

  <div class="mt-3">
    <%= f.submit "Log In", class: "btn btn-primary btn-lg" %>
    <%= nav_tab 'Sign Up', new_user_path, class: 'btn btn-secondary btn-lg'%>
  </div>

<%end%>